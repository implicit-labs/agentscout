{
  "name": "@implicit-ai/agentscout",
  "version": "0.1.0",
  "description": "Your agents should shop for their own tools. Analyzes Claude Code sessions to find workflow inefficiencies and recommend tools.",
  "type": "module",
  "bin": {
    "agentscout": "./dist/cli.js"
  },
  "files": [
    "dist",
    "scripts",
    ".claude/commands",
    "examples"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/implicit-labs/agentscout.git"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run build",
    "postinstall": "node scripts/postinstall.js"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "mcp",
    "ai-tools",
    "agent",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.72",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  }
}
